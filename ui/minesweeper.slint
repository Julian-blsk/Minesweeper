import { Button } from "std-widgets.slint";

export struct CellData {
    x: int,
    y: int,
    is_mine: bool,
    is_revealed: bool,
    number: string,
    is_flagged: bool,
}

export component MainWindow inherits Window {
    preferred-width: 600px;
    preferred-height: 700px;
    title: "Minesweeper";

    callback cell_clicked(x: int, y: int);
    callback start_easy();
    callback start_hard();
    callback cell_right_clicked(x: int, y: int);

    in-out property <string> game_status;
    in-out property <int> mines_left;
    in-out property <[CellData]> cells;

    VerticalLayout {
        alignment: start;
        spacing: 10px;
        padding: 10px;

        Text {
            text: "Minen: " + root.mines_left;
            font-size: 20px;
            horizontal-alignment: center;
            visible: game_status == "Laufend";
        }

        Text {
            text: root.game_status;
            font-size: 24px;
            horizontal-alignment: center;
        }

        Button {
            text: "Easy";
            visible: game_status == "Hauptmenü";
            clicked => {
                root.start_easy();
            }
        }

        Button {
            visible: game_status == "Hauptmenü";
            text: "Hard";
            clicked => {
                root.start_hard();
            }
        }

        GridLayout {
            visible: game_status != "Hauptmenü";
            spacing: 2px;

            for cell_data in cells: Rectangle {
                property <int> current_index: -1;

                timer := Timer {
                    interval: 30ms;
                    running: false;
                    triggered => {
                        current_index = (current_index + 1);
                        if current_index >= 7 {
                            timer.running = false;
                            current_index = -1;
                        }
                    }
                }

                width: 35px;
                height: 35px;
                row: cell_data.y;
                col: cell_data.x;

                background: {
                    if cell_data.is_flagged {
                        #44ff44
                    } else if !cell_data.is_revealed {
                        #4444ff
                    } else if cell_data.is_mine {
                        #ff4444
                    } else {
                        #cccccc
                    }
                }

                border-width: 1px;
                border-color: #000000;

                Text {
                    text: cell_data.number;
                    color: black;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                    visible: cell_data.is_revealed && !cell_data.is_flagged && !cell_data.is_mine;
                }

                Image {
                    source: @image-url("flag.png");
                    width: 30px;
                    height: 30px;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                    visible: cell_data.is_flagged;
                }

                Image {
                    visible: cell_data.is_mine && cell_data.is_revealed;
                    width: 30px;
                    height: 30px;
                    states [
                        zero when current_index == 0: {
                            source: @image-url("bomb.png");
                        }
                        one when current_index == 1: {
                            source: @image-url("bomb_1.jpeg");
                        }
                        two when current_index == 2: {
                            source: @image-url("Bomb_2.jpeg");
                        }
                        three when current_index == 3: {
                            source: @image-url("Bomb_3.jpeg");
                        }
                        four when current_index == 4: {
                            source: @image-url("Bomb_4.jpeg");
                        }
                        five when current_index == 5: {
                            source: @image-url("Bomb_5.jpeg");
                        }
                        six when current_index == 6: {
                            source: @image-url("Bomb_6.jpeg");
                        }
                        seven when current_index == 7: {
                            source: @image-url("Bomb_7.jpeg");
                        }
                    ]
                }

                TouchArea {
                    clicked => {
                        root.cell_clicked(cell_data.x, cell_data.y);
                        if cell_data.is_mine && cell_data.is_revealed {
                            current_index = 0;
                            timer.running = true;
                        }
                    }
                    pointer-event(event) => {
                        if (event.button == PointerEventButton.right && event.kind == PointerEventKind.down) {
                            root.cell_right_clicked(cell_data.x, cell_data.y);
                        }
                    }
                }
            }
        }
    }
}
